# ─────────────── Authentification ───────────────
# Les comptes sont stockés en base (table users). AUTH_USERNAME + AUTH_PASSWORD_HASH_B64
# servent de compte "bootstrap" : au tout premier login avec ces identifiants,
# le compte est créé en base et tes données existantes y sont rattachées.
AUTH_USERNAME=army

# Mot de passe du compte bootstrap, hashé puis encodé base64. Génère-le avec :
#   npm run hash-password "TonMotDePasse"
AUTH_PASSWORD_HASH_B64=

# (Alternative sans hash, à éviter. Pas de $ dans le mot de passe en local.)
# AUTH_PASSWORD=

# Secret de signature du cookie de session. 32+ caractères aléatoires :
#   openssl rand -base64 32
AUTH_SECRET=

# Code d'invitation pour l'inscription (/signup). Laisse vide pour désactiver
# la création de comptes. Donne ce code à la personne que tu veux inviter.
SIGNUP_INVITE_CODE=

# ─────────────── Base de données (Vercel Postgres / Neon) ───────────────
# Fournie automatiquement par l'intégration Vercel Postgres.
# En local : `vercel env pull .env.local`
DATABASE_URL=

# ─────────────── Photos (Vercel Blob) ───────────────
# Fournie automatiquement par l'intégration Vercel Blob.
BLOB_READ_WRITE_TOKEN=
