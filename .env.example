# ─────────────── Authentification (un seul utilisateur) ───────────────
# Ton identifiant de connexion
AUTH_USERNAME=army

# Mot de passe HASHÉ puis encodé en base64 (recommandé). Génère-le avec :
#   npm run hash-password "TonMotDePasse"
# puis colle le résultat ici.
AUTH_PASSWORD_HASH_B64=

# (Alternative sans hash, plus simple mais moins sûre — laisse AUTH_PASSWORD_HASH_B64 vide si tu l'utilises.
#  Évite les caractères $ dans le mot de passe en local.)
# AUTH_PASSWORD=

# Secret de signature du cookie de session. 32+ caractères aléatoires. Génère-le avec :
#   openssl rand -base64 32
AUTH_SECRET=

# ─────────────── Base de données (Vercel Postgres / Neon) ───────────────
# Fournie automatiquement par l'intégration Vercel Postgres.
# En local : `vercel env pull .env.local`
DATABASE_URL=

# ─────────────── Photos (Vercel Blob) ───────────────
# Fournie automatiquement par l'intégration Vercel Blob.
BLOB_READ_WRITE_TOKEN=
